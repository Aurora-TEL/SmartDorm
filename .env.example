# SmartDorm environment example

COMPOSE_PROJECT_NAME=smartdorm
ENVIRONMENT=production
TZ=Asia/Shanghai

POSTGRES_DB=smartdorm
POSTGRES_USER=smartdorm
POSTGRES_PASSWORD=smartdorm_change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://smartdorm:smartdorm_change_me@db:5432/smartdorm

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_ENABLE_MOCK_FALLBACK=false
